# Copie este arquivo para .env e preencha os valores

# Ambiente: development | production
NODE_ENV=development

# Chave secreta para assinatura das sessões (use uma string longa e aleatória em produção)
SESSION_SECRET=troque_por_uma_string_aleatoria_longa_aqui

# Porta do servidor (opcional, padrão: 3000)
PORT=3000
